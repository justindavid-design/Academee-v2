# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vite client env (prefix with VITE_)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ========== Google OAuth 2.0 Configuration ==========
# Get these from: https://console.cloud.google.com/
# Frontend - Google Client ID (safe to expose in browser)
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com
# Backend - Google Client Secret (SENSITIVE - never commit!)
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE
# JWT Secret for token generation (generate: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_32_character_string_here

# Local API dev server
API_PORT=8787
API_HOST=0.0.0.0
NODE_ENV=development

# Vercel (optional)
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# SMTP settings for OTP / password reset email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=your-email@gmail.com
